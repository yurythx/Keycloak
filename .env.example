# Copie este arquivo para ".env" e ajuste os valores.
# ".env" nunca deve ser commitado (já está no .gitignore).

# --- Banco de dados ---
POSTGRES_DB=keycloak
POSTGRES_USER=keycloak_user
# Senha real fica em secrets/postgres_password.txt (gerado por scripts/generate-secrets.ps1)

# --- Admin inicial do Keycloak ---
KC_BOOTSTRAP_ADMIN_USERNAME=kc_admin
# Senha real fica em secrets/kc_admin_password.txt

# --- Hostname público (o que os usuários/apps vão usar para autenticar) ---
KC_HOSTNAME=https://auth.suaempresa.com
KC_LOG_LEVEL=INFO

# IPs/CIDRs dos proxies confiáveis para os cabeçalhos X-Forwarded-* (o Nginx
# deste compose já entra na rede interna; ajuste se houver outro proxy na frente)
PROXY_TRUSTED_ADDRESSES=172.16.0.0/12

# --- Integração com Active Directory ---
AD_DOMAIN=meudominio.local
AD_DC_HOSTNAME=dc01.meudominio.local
AD_DC_IP=192.168.1.10
